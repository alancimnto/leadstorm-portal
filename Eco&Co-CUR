let currentProfile = 0;
let currentTab = 'persona';

function switchProfile(idx) {
    currentProfile = idx;
    renderProfileTabs();
    renderContent();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function switchTab(tabId) {
    currentTab = tabId;
    document.getElementById('mobile-section-select').value = tabId;
    renderSidebarNav();
    renderContent();
}

function renderProfileTabs() {
    const container = document.getElementById('profile-tabs');
    container.innerHTML = DATA.profiles.map((p, i) => `
        <button class="ptab ${i === currentProfile ? 'active' : ''}" onclick="switchProfile(${i})">
            ${p.emoji} ${p.name.split(' ')[0]}
        </button>
    `).join('');
}

function renderSidebarNav() {
    const container = document.getElementById('sidebar-nav');
    container.innerHTML = Object.keys(SECTION_META).map(key => `
        <button class="stab ${key === currentTab ? 'active' : ''}" onclick="switchTab('${key}')">
            <span>${SECTION_META[key].icon}</span> ${key === 'objeciones' ? '60 Objeciones' : SECTION_META[key].title.replace('<em>','').replace('</em>','')}
        </button>
    `).join('');
}

function renderContent() {
    const p = DATA.profiles[currentProfile];
    const meta = SECTION_META[currentTab];
    const el = document.getElementById('main-content');
    
    let html = `
        <div class="section-header">
            <span class="section-badge">${meta.tag}</span>
            <h1 class="section-h1">${meta.title}</h1>
            <p class="section-p">${meta.desc}</p>
        </div>`;

    if (currentTab === 'persona') {
        const sc = p.scores;
        const bars = [['Dolor',sc.dolor],['Poder $',sc.poder],['Target',sc.target],['Crecimiento',sc.crecimiento],['Encanta',sc.encanta],['Transforma',sc.transforma]];
        html += `
            <div class="quote-card"><p>${p.frase}</p></div>
            <div class="persona-grid">
                <div class="info-box"><h4>Cargo típico</h4><p>${p.cargo}</p></div>
                <div class="info-box"><h4>Empresa</h4><p>${p.empresa}</p></div>
                <div class="info-box"><h4>Decisión</h4><p>${p.decision}</p></div>
                <div class="info-box"><h4>Día a día</h4><p>${p.contexto}</p></div>
            </div>
            <div class="info-box" style="margin-top:20px">
                <h4>Scoring de Rentabilidad</h4>
                <div style="margin-top:15px">
                    ${bars.map(([l,v])=>`
                    <div class="score-row">
                        <div class="score-header"><span>${l.toUpperCase()}</span><span>${v}/10</span></div>
                        <div class="bar-bg"><div class="bar-fill" style="width:${v*10}%"></div></div>
                    </div>`).join('')}
                </div>
                <div style="margin-top:15px; text-align:right; font-weight:800; color:var(--red); font-size:18px">Total: ${sc.total}/60</div>
            </div>`;
    } else if (currentTab === 'objeciones') {
        const groups = [
            {t:'Internas — Cabeza', d: p.objeciones.internas, c:'accent-red'},
            {t:'Externas — Entorno', d: p.objeciones.externas, c:'accent-navy'},
            {t:'Vehículo — Producto', d: p.objeciones.vehiculo, c:'accent-slate'}
        ];
        html += groups.map(g => `
            <h3 style="font-size:12px; margin: 25px 0 10px; text-transform:uppercase; color:var(--slate); font-weight:800; letter-spacing:0.1em">${g.t}</h3>
            ${g.d.map((item, i) => `
                <div class="card ${g.c}"><div class="card-num">${i+1}</div><div class="card-content">${item}</div></div>
            `).join('')}`).join('');
    } else if (currentTab === 'preguntas') {
        html += p.preguntas.map((item,i) => `
            <div class="info-box" style="margin-bottom:12px">
                <p style="color:var(--red); font-size:10px; font-weight:800; margin-bottom:5px">PREGUNTA ${i+1}</p>
                <p style="margin-bottom:10px; font-weight:700; color:var(--navy)">${item.q}</p>
                <p style="font-weight:400; font-style:italic; border-left:2px solid var(--red); padding-left:15px; color:var(--text-mid)">${item.a}</p>
            </div>`).join('');
    } else {
        const listMap = {
            'dolores-e':'doloresE', 'dolores-o':'doloresO', 'miedos':'miedos',
            'deseos-e':'deseosE', 'deseos-s':'deseosS', 'promesas':'promesas'
        };
        const accentMap = {
            'dolores-e':'accent-red', 'dolores-o':'accent-navy', 'miedos':'accent-slate',
            'deseos-e':'accent-red', 'deseos-s':'accent-navy', 'promesas':'accent-red'
        };
        html += p[listMap[currentTab]].map((item, i) => `
            <div class="card ${accentMap[currentTab]}">
                <div class="card-num">${i+1}</div>
                <div class="card-content">${item}</div>
            </div>`).join('');
    }
    el.innerHTML = html;
}

renderProfileTabs();
renderSidebarNav();
renderContent();
</script>
